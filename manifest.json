{
  "manifest_version": 3,
  "name": "Buscador Shalom Control",
  "version": "2.0.0",
  "description": "Buscador avanzado y catálogo de agencias para el sistema de control de Shalom.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://*.shalom.pe/*",
    "https://*.shalomcontrol.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.shalom.pe/*", "https://*.shalomcontrol.com/*"],
      "js": ["agencyStore.js", "content.js"],
      "run_at": "document_end"
    }
  ]
}
